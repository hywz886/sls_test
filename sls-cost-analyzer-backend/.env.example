# SLS Cost Analyzer Backend - 环境变量配置

# 🤖 大模型 API 配置（可选，用于 AI 日志分析）
# 如果不配置，将使用内置的基础分析逻辑

# 阿里云百炼（通义千问）
LLM_API_KEY=sk-your-api-key-here
LLM_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# 或使用其他大模型服务（DeepSeek、Moonshot 等）
# LLM_API_ENDPOINT=https://api.deepseek.com/v1/chat/completions
# LLM_API_ENDPOINT=https://api.moonshot.cn/v1/chat/completions

# 📁 数据目录配置
SOURCE_DIR=/root/.openclaw/workspace/data
DATA_DIR=/opt/data

# 🌐 服务器配置
PORT=3000
